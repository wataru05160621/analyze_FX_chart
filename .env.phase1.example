# Phase 1: アラートシステムの環境変数設定例

# Slack Webhook設定
# Slack App管理画面から取得: https://api.slack.com/apps
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# TradingView Webhook設定
# 自身のサーバーでWebhookエンドポイントを用意
TRADINGVIEW_WEBHOOK_URL=https://your-domain.com/webhook/tradingview

# メール通知設定
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-app-password  # Gmailの場合はアプリパスワードを使用
RECIPIENT_EMAIL=recipient@example.com

# AWS設定（オプション）
AWS_REGION=ap-northeast-1
PERFORMANCE_TABLE=fx-trading-signals
