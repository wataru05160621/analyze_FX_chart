# OpenAI API設定
OPENAI_API_KEY=your_openai_api_key_here

# Notion API設定
NOTION_API_KEY=your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Trading View設定（必要に応じて）
TRADINGVIEW_CUSTOM_URL=https://jp.tradingview.com/chart/xxxxx/  # あなたのチャートURL

# ChatGPT Web設定
CHATGPT_EMAIL=your_chatgpt_email
CHATGPT_PASSWORD=your_chatgpt_password
CHATGPT_PROJECT_NAME=FXチャート分析  # プロジェクト名

# 分析モード設定
USE_WEB_CHATGPT=true  # true: Web版ChatGPTを使用, false: APIを使用