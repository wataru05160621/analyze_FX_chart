# OpenAI API設定
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Claude API設定
CLAUDE_API_KEY=sk-ant-api03-your_claude_api_key_here

# Notion API設定
NOTION_API_KEY=ntn_your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Trading View設定（必要に応じて）
TRADINGVIEW_CUSTOM_URL=https://jp.tradingview.com/chart/xxxxx/  # あなたのチャートURL

# ChatGPT Web設定
CHATGPT_EMAIL=your_chatgpt_email_here
CHATGPT_PASSWORD=your_chatgpt_password_here
CHATGPT_PROJECT_NAME=FXチャート分析  # プロジェクト名

# 分析モード設定
USE_WEB_CHATGPT=false  # true: Web版ChatGPTを使用, false: APIを使用
ANALYSIS_MODE=openai  # openai, claude, web_chatgpt

# 画像アップロード設定（いずれか一つを選択）

# Imgurを使用する場合
IMGUR_CLIENT_ID=your_imgur_client_id

# Cloudinaryを使用する場合
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3を使用する場合
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=ap-northeast-1

# WordPress設定（ブログ自動投稿用）
WORDPRESS_URL=https://your-domain.com
WORDPRESS_USERNAME=your_username_here
WORDPRESS_PASSWORD=your_application_password_here

# X (Twitter) API設定
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# ブログ投稿設定
ENABLE_BLOG_POSTING=false  # true にすると8:00の分析をブログに投稿
BLOG_POST_HOUR=8  # 投稿する分析の時間（JST）

# WordPress タクソノミー設定
WORDPRESS_CATEGORY_USDJPY=4  # ドル円カテゴリID
WORDPRESS_CATEGORY_ANALYSIS=3  # 分析カテゴリID
WORDPRESS_TAG_DAILY_USDJPY=2  # 日次ドル円分析タグID