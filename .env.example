# OpenAI API設定
OPENAI_API_KEY=sk-proj-your_openai_api_key_here

# Claude API設定
CLAUDE_API_KEY=sk-ant-api03-your_claude_api_key_here

# Notion API設定
NOTION_API_KEY=ntn_your_notion_api_key_here
NOTION_DATABASE_ID=your_notion_database_id_here

# Trading View設定（必要に応じて）
TRADINGVIEW_CUSTOM_URL=https://jp.tradingview.com/chart/xxxxx/  # あなたのチャートURL

# ChatGPT Web設定
CHATGPT_EMAIL=your_chatgpt_email_here
CHATGPT_PASSWORD=your_chatgpt_password_here
CHATGPT_PROJECT_NAME=FXチャート分析  # プロジェクト名

# 分析モード設定
USE_WEB_CHATGPT=false  # true: Web版ChatGPTを使用, false: APIを使用
ANALYSIS_MODE=openai  # openai, claude, web_chatgpt

# 画像アップロード設定（いずれか一つを選択）

# Imgurを使用する場合
IMGUR_CLIENT_ID=your_imgur_client_id

# Cloudinaryを使用する場合
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# AWS S3を使用する場合
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET=your_bucket_name
AWS_REGION=ap-northeast-1